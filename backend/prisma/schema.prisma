generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Link {
  id        String   @id @default(uuid())
  slug      String   @unique
  url       String
  createdAt DateTime @default(now())
  clicks    Click[]
}

model Click {
  id        String   @id @default(uuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  ipHash    String   @map("ip_hash")
  country   String?
  referrer  String?
  createdAt DateTime @default(now())
}
